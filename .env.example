# ─── Variáveis de ambiente (modelo) ───────────────────────────────
# COPIE este arquivo para ".env" e preencha com seus valores reais.
# O arquivo .env real NUNCA vai para o Git (está no .gitignore).
#
#   cp .env.example .env
#
# Na Fase 2/3 vamos rodar TUDO local e grátis (sem precisar de chaves).
# Estas variáveis só são necessárias a partir da Fase 4 (LLM) e Fase 7 (Azure).

GROQ_API_KEY=gsk_cole_sua_chave_aqui

# ─── Azure OpenAI (Fase 4 em diante) ──────────────────────────────
AZURE_OPENAI_ENDPOINT=https://SEU-RECURSO.openai.azure.com/
AZURE_OPENAI_API_KEY=sua-chave-aqui
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini      # nome do seu deployment de chat
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small

# ─── Azure AI Search (Fase 7) ─────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://SEU-SERVICO.search.windows.net
AZURE_SEARCH_API_KEY=sua-chave-aqui
AZURE_SEARCH_INDEX=rag-documentos

# ─── Modo de operação ─────────────────────────────────────────────
# "local"  = embeddings e índice na sua máquina (grátis, Fases 2-6)
# "azure"  = usa serviços Azure (Fase 7)
MODO=local
